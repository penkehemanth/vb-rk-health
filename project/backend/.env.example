# ============================================================
# RK Health - Backend Configuration
# Copy this file to .env and fill in your credentials
# ============================================================

# --- AI Backend: 'groq' (cloud) or 'ollama' (local) ---
AI_BACKEND=groq

# --- Groq AI (for chatbot & summaries) ---
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Ollama (local AI, only used when AI_BACKEND=ollama) ---
# Install from https://ollama.com, then pull a model:
#   ollama pull llama3.1:8b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Twilio SMS (for medication/appointment reminders) ---
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# --- Google Apps Script Web App URL ---
# Deploy the Apps Script project (appsscript.gs) as a Web App
# and paste the deployment URL here
GAS_URL=https://script.google.com/macros/s/your_deployment_id/exec

# --- Flask Server ---
PORT=5000
FLASK_DEBUG=true
